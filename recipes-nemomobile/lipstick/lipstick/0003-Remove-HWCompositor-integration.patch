-            qCDebug(LIPSTICK_LOG_HWC, "Missing required EGL extension: '%s'", nativeBuffer2Extensions);
-        }
-
-        // If both extensions were found
-        if (checked == (0x1 | 0x2)) {
-            qCDebug(LIPSTICK_LOG_HWC, "HWC composition of window surfaces is enabled");
