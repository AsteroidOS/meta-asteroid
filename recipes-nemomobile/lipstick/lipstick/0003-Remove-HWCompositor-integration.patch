-void HwcImageTexture::bind()
-{
-    glBindTexture(GL_TEXTURE_2D, m_id);
-    updateBindOptions(!m_bound);
-    if (!m_bound) {
-        m_bound = true;
-        glEGLImageTargetTexture2DOESlipstick(GL_TEXTURE_2D, m_image);
-    }
-}
