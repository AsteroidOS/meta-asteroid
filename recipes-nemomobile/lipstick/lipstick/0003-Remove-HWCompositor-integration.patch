-public:
-    LipstickCompositorWindowReleaseEvent(LipstickCompositorWindowHwcNode *n)
-        : QEvent(QEvent::User)
-        , eventTarget(n->renderStage())
-        , eglBuffer(n->eglBuffer)
-        , waylandBuffer(n->waylandBuffer)
