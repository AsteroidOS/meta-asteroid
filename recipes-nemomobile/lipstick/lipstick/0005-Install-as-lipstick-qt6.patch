From bccdf2ab9d66f8a4c2bf8c86d4a925228c9bb765 Mon Sep 17 00:00:00 2001
From: Florent Revest <revestflo@gmail.com>
Date: Thu, 30 Apr 2026 21:53:45 +0000
Subject: [PATCH 5/5] Install as lipstick-qt6

Upstream-Status: Inappropriate
---
 plugin/plugin.pro                           | 2 +-
 src/src.pro                                 | 4 ++--
 tools/notificationtool/notificationtool.pro | 2 +-
 3 files changed, 4 insertions(+), 4 deletions(-)

diff --git a/plugin/plugin.pro b/plugin/plugin.pro
index 0a2e1d20..b174f062 100644
--- a/plugin/plugin.pro
+++ b/plugin/plugin.pro
@@ -13,7 +13,7 @@ target.path = $$[QT_INSTALL_QML]/org/nemomobile/lipstick
 
 DEPENDPATH += "../src"
 INCLUDEPATH += "../src" "../src/utilities" "../src/xtools" "../src/compositor" "../src/qmsystem2"
-LIBS += -L"../src" -llipstick-qt5
+LIBS += -L"../src" -llipstick-qt6
 
 HEADERS += \
     lipstickplugin.h
diff --git a/src/src.pro b/src/src.pro
index 0d054abb..8051c7cb 100644
--- a/src/src.pro
+++ b/src/src.pro
@@ -5,7 +5,7 @@ system(qdbusxml2cpp screenshotservice.xml -a screenshotserviceadaptor -c Screens
 system(qdbusxml2cpp shutdownscreen.xml -a shutdownscreenadaptor -c ShutdownScreenAdaptor -l ShutdownScreen -i shutdownscreen.h)
 
 TEMPLATE = lib
-TARGET = lipstick-qt5
+TARGET = lipstick-qt6
 
 # Override the version from the spec file, we need .so version 1.0
 VERSION = 1.0
@@ -60,7 +60,7 @@ PUBLICHEADERS += \
 
 INSTALLS += publicheaderfiles dbus_policy
 publicheaderfiles.files = $$PUBLICHEADERS
-publicheaderfiles.path = /usr/include/lipstick-qt5
+publicheaderfiles.path = /usr/include/lipstick-qt6
 dbus_policy.files += lipstick.conf
 dbus_policy.path = /etc/dbus-1/system.d
 
diff --git a/tools/notificationtool/notificationtool.pro b/tools/notificationtool/notificationtool.pro
index a2d52980..e67c7d07 100644
--- a/tools/notificationtool/notificationtool.pro
+++ b/tools/notificationtool/notificationtool.pro
@@ -13,7 +13,7 @@ target.path = /usr/bin
 DEPENDPATH += "../../src"
 INCLUDEPATH += "../../src" "../../src/notifications" "../../src/qmsystem2"
 QMAKE_LIBDIR = ../../src
-LIBS = -llipstick-qt5
+LIBS = -llipstick-qt6
 
 HEADERS += \
      notificationmanagerproxy.h
-- 
2.47.3

