From c129532506d059b23ca7e9ca1e0da2517b44fb02 Mon Sep 17 00:00:00 2001
From: Florent Revest <revestflo@gmail.com>
Date: Fri, 24 Apr 2026 09:24:35 +0000
Subject: [PATCH] libhybris-egl-server: Fix build

This replicates changes done in other hardwareintegration plugins but
missing from the libhybris egl server specifically.

Upstream-Status: Inappropriate
---
 .../hardwareintegration/libhybris-egl-server/CMakeLists.txt     | 2 ++
 .../libhybriseglserverbufferintegration.cpp                     | 2 +-
 2 files changed, 3 insertions(+), 1 deletion(-)

diff --git a/src/plugins/platforms/wayland/plugins/hardwareintegration/libhybris-egl-server/CMakeLists.txt b/src/plugins/platforms/wayland/plugins/hardwareintegration/libhybris-egl-server/CMakeLists.txt
index 66989154826..66d908671b6 100644
--- a/src/plugins/platforms/wayland/plugins/hardwareintegration/libhybris-egl-server/CMakeLists.txt
+++ b/src/plugins/platforms/wayland/plugins/hardwareintegration/libhybris-egl-server/CMakeLists.txt
@@ -17,6 +17,7 @@ qt_internal_add_plugin(LibHybrisEglServerBufferPlugin
         EGL::EGL
         Qt::Core
         Qt::Gui
+        Qt::OpenGL
         Qt::WaylandClientPrivate
         Wayland::Client
     QT_LICENSE_ID QT_COMMERCIAL_OR_LGPL3
@@ -26,6 +27,7 @@ qt6_generate_wayland_protocol_client_sources(LibHybrisEglServerBufferPlugin
     PRIVATE_CODE
     FILES
         ${CMAKE_CURRENT_SOURCE_DIR}/../../../../../../3rdparty/wayland/extensions/libhybris-egl-server-buffer.xml
+        ${CMAKE_CURRENT_SOURCE_DIR}/../../../../../../3rdparty/wayland/extensions/server-buffer-extension.xml
 )
 
 #### Keys ignored in scope 1:.:.:libhybris-egl-server.pro:<TRUE>:
diff --git a/src/plugins/platforms/wayland/plugins/hardwareintegration/libhybris-egl-server/libhybriseglserverbufferintegration.cpp b/src/plugins/platforms/wayland/plugins/hardwareintegration/libhybris-egl-server/libhybriseglserverbufferintegration.cpp
index 38b9a5e686e..640a2cd5170 100644
--- a/src/plugins/platforms/wayland/plugins/hardwareintegration/libhybris-egl-server/libhybriseglserverbufferintegration.cpp
+++ b/src/plugins/platforms/wayland/plugins/hardwareintegration/libhybris-egl-server/libhybriseglserverbufferintegration.cpp
@@ -6,7 +6,7 @@
 #include <QtWaylandClient/private/qwaylanddisplay_p.h>
 #include <QDebug>
 #include <QtGui/QOpenGLContext>
-#include <QtGui/QOpenGLTexture>
+#include <QOpenGLTexture>
 #include <hybris/eglplatformcommon/hybris_nativebufferext.h>
 
 #include <EGL/egl.h>
