+// Copyright (C) 2026 AsteroidOS
+// SPDX-License-Identifier: LicenseRef-Qt-Commercial OR LGPL-3.0-only OR GPL-2.0-only OR GPL-3.0-only
+#ifndef QMLSTEPCOUNTERSENSOR_P_H
+#define QMLSTEPCOUNTERSENSOR_P_H
+
+//
+//  W A R N I N G
+//  -------------
+//
+// This file is not part of the Qt API.  It exists purely as an
+// implementation detail.  This header file may change from version to
+// version without notice, or even be removed.
+//
+// We mean it.
+//
+
+#include "qmlsensor_p.h"
+
+QT_BEGIN_NAMESPACE
+
+class QStepCounterSensor;
+
+class Q_SENSORSQUICK_EXPORT QmlStepCounterSensor : public QmlSensor
+{
+    Q_OBJECT
+    QML_NAMED_ELEMENT(StepCounterSensor)
+    QML_ADDED_IN_VERSION(5,9)
+public:
+    explicit QmlStepCounterSensor(QObject *parent = 0);
+    ~QmlStepCounterSensor();
+    QSensor *sensor() const override;
+
+private:
+    QmlSensorReading *createReading() const override;
+
+    QStepCounterSensor *m_sensor;
+};
+
+class Q_SENSORSQUICK_EXPORT QmlStepCounterReading : public QmlSensorReading
+{
+    Q_OBJECT
+    Q_PROPERTY(int steps READ steps
+               NOTIFY stepsChanged BINDABLE bindableSteps)
+    QML_NAMED_ELEMENT(StepCounterReading)
+    QML_UNCREATABLE("Cannot create StepCounterReading")
+    QML_ADDED_IN_VERSION(5,9)
+public:
+    explicit QmlStepCounterReading(QStepCounterSensor *sensor);
+    ~QmlStepCounterReading();
+
+    int steps() const;
+    QBindable<int> bindableSteps() const;
+
+Q_SIGNALS:
+    void stepsChanged(int steps);
+
+private:
+    QSensorReading *reading() const override;
+    void readingUpdate() override;
+
+    QStepCounterSensor *m_sensor;
+    Q_OBJECT_BINDABLE_PROPERTY(QmlStepCounterReading, int,
+                               m_steps, &QmlStepCounterReading::stepsChanged)
+};
+
+QT_END_NAMESPACE
+#endif
