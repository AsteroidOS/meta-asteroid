From 78e76c2607ce46b0d5d1351e37a404b14abe5ccf Mon Sep 17 00:00:00 2001
From: casept <davids.paskevics@gmail.com>
Date: Thu, 5 Mar 2026 12:20:59 +0100
Subject: [PATCH] Fix pulseaudio linkage
Upstream-Status: Inappropriate

---
 meson.build                         | 16 +++++++++++-----
 src/stream-restore-nemo/meson.build |  4 ++--
 2 files changed, 13 insertions(+), 7 deletions(-)

diff --git a/meson.build b/meson.build
index d521e8a..c239f7e 100644
--- a/meson.build
+++ b/meson.build
@@ -24,17 +24,23 @@ version_split = pa_version_str.split('-')[0].split('.')
 pa_version_major = version_split[0].split('v')[0]
 pa_version_minor = version_split[1]
 pa_version_major_minor = pa_version_major + '.' + pa_version_minor
-project_version_str = meson.project_version()
-project_version_split = project_version_str.split('-')[0].split('.')
-pa_version_module = project_version_split[2].split('+')[0]
-
-pa_c_args = ['-DHAVE_CONFIG_H', '-DPULSEAUDIO_VERSION=' + pa_version_major]
 
 modlibexecdir = get_option('modlibexecdir')
 if modlibexecdir == ''
   modlibexecdir = join_paths(libdir, 'pulse-' + pa_version_major_minor, 'modules')
 endif
 
+protocol_native_dep = cc.find_library('protocol-native', dirs : modlibexecdir, required : false)
+if not protocol_native_dep.found()
+  protocol_native_dep = declare_dependency(link_args : ['-lprotocol-native'])
+endif
+
+project_version_str = meson.project_version()
+project_version_split = project_version_str.split('-')[0].split('.')
+pa_version_module = project_version_split[0]
+
+pa_c_args = ['-DHAVE_CONFIG_H', '-DPULSEAUDIO_VERSION=' + pa_version_major]
+
 privlibdir = join_paths(libdir, 'pulseaudio')
 rpath_dirs = join_paths(privlibdir) + ':' + join_paths(modlibexecdir)
 
diff --git a/src/stream-restore-nemo/meson.build b/src/stream-restore-nemo/meson.build
index 759eb38..fe3f66d 100644
--- a/src/stream-restore-nemo/meson.build
+++ b/src/stream-restore-nemo/meson.build
@@ -1,10 +1,10 @@
 module_stream_restore_nemo = library('module-stream-restore-nemo',
   'module-stream-restore-nemo.c',
   c_args : [pa_c_args, '-DPA_MODULE_NAME=module_stream_restore_nemo'],
-  link_args : ['-L'+libdir+'/pulse-'+pa_version_major_minor+'/modules', '-lprotocol-native'],
+  link_args : ['-L'+libdir+'/pulse-'+pa_version_major_minor+'/modules'],
   install : true,
   install_dir : modlibexecdir,
   install_rpath : rpath_dirs,
-  dependencies : [meego_common_dep],
+  dependencies : [meego_common_dep, pulsecore_dep, protocol_native_dep ],
   name_prefix : ''
 )
